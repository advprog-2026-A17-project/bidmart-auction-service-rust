# Auction service local env
# Local repo values are used first, then bidmart-infrastructure/.env if present

# Server
BIND_ADDRESS=0.0.0.0:8082

# Database
# VPS host is IPv4-only. Use Supabase Session Pooler (NOT db.<ref>.supabase.co direct, which is IPv6-only).
# Copy host from Supabase Dashboard → Connect → Session pooler (aws-1-<region>.pooler.supabase.com).
# Example (auction project ref begunupzsnlftbsdgmxw):
# DATABASE_URL=postgresql://postgres.begunupzsnlftbsdgmxw:<password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bidmart_auction

# Downstream (VPS Compose — see bidmart-infrastructure/docs/DEPLOYMENT_URLS.md)
CATALOGUE_SERVICE_URL=http://localhost:8081
CATALOGUE_GRPC_URL=http://catalogue-service:9091
WALLET_SERVICE_URL=http://localhost:8083
WALLET_GRPC_URL=http://wallet-service:50051
# Public gateway (for external callbacks only): https://bidmart-staging.43.157.208.68.sslip.io

# RabbitMQ outbox publisher
RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2f
BIDMART_EVENTS_EXCHANGE=bidmart.events

# Internal service authentication
GATEWAY_INTERNAL_TOKEN=bidmart-local-internal-token

# Schedulers (milliseconds)
AUCTION_CLOSURE_SCHEDULER_INTERVAL_MS=1000
OUTBOX_SCHEDULER_INTERVAL_MS=1000

# Bid hold grace after auction end (seconds, default 72h)
BID_HOLD_GRACE_SECONDS=259200

# Swagger UI (docker-compose)
SWAGGER_UI_PORT=8088
